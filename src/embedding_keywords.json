            "id": "secrets_credentials",
            "name": "Secrets / Credentials",
            "description": "Contains authentication credentials, API keys, tokens, passwords, or private keys.",
            "priority": 100,
            "keywords": [
                "api key",
                "secret",
                "token",
                "access token",
                "bearer token",
                "auth",
                "authentication",
                "credential",
                "password",
                "private key",
                "public key",
                "ssh key",
                "jwt",
                "refresh token",
                "session token",
                "client secret",
                "api secret"
            ],
            "patterns": [
                "ghp_[A-Za-z0-9]{20,}",
                "sk-[A-Za-z0-9_-]{10,}",
                "AKIA[0-9A-Z]{16}",
                "-----BEGIN PRIVATE KEY-----",
                "[A-Z][A-Z0-9_]*(KEY|SECRET|TOKEN|PASSWORD|PASS|API|AUTH|CREDENTIAL)[A-Z0-9_]*\\s*="
            ]
